{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "claudeflare-worker",
	"main": "src/index.js",
	"compatibility_date": "2026-06-20",
	"compatibility_flags": ["nodejs_compat"],

	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,

	"analytics_engine_datasets": [
		{
			"binding": "ANALYTICS",
			"dataset": "my_dataset",
		},
	],
}
